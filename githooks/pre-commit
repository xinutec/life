#!/usr/bin/env bash
# life pre-commit — the single health gate. A commit must be healthy, so this
# runs the FULL verify: backend fmt + clippy + generated-types drift, frontend
# lint + build + unit tests + phone-width ui-check, and the shared dev-lint
# rules. There is no separate pre-push step — everything runs here.
#
# Slow by design (minutes): we optimise for healthy commits, not commit speed.
# Bypass a genuine work-in-progress commit with:  git commit --no-verify
#
# Activate once per clone:  git config core.hooksPath githooks
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"
exec scripts/verify.sh
